# ============================================================================
# CourseHub environment — copy to .env.local and fill in.
# NEVER commit .env.local. Only this template (.env.example) is committed.
# ============================================================================

# ---- Supabase (required) ---------------------------------------------------
# Project URL + publishable (anon) key — safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx

# Service-role / secret key — SERVER ONLY, bypasses RLS. Required for the
# Stripe webhook sync, admin tooling and seeding. Copy from:
#   Supabase Dashboard > Project Settings > API > service_role / secret key
SUPABASE_SERVICE_ROLE_KEY=

# ---- App -------------------------------------------------------------------
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Media (Cloudflare Stream) --------------------------------------------
# MEDIA_PROVIDER=mock plays a sample HLS so the player works with no account.
# Set to "cloudflare" and fill the rest to enable real, signed video playback.
MEDIA_PROVIDER=mock
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_STREAM_API_TOKEN=
CLOUDFLARE_STREAM_KEY_ID=
CLOUDFLARE_STREAM_JWK=

# ---- Stripe (test mode) ----------------------------------------------------
# Leave blank to run billing in mock mode. Fill to enable Checkout + webhooks.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price ids (create products/prices in Stripe, or run `npm run stripe:seed`)
STRIPE_PRICE_BASIC_MONTHLY=
STRIPE_PRICE_BASIC_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_PREMIUM_MONTHLY=
STRIPE_PRICE_PREMIUM_YEARLY=

# ---- Rate limiting (optional, for multi-instance prod) ---------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
